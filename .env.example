# EVM chain config (required)
ETH_CHAIN=sepolia
ETH_RPC=
ETH_CHAIN_ID=11155111
ETH_FROM_ADDRESS=
ETH_WITHDRAW_GAS_RESERVE_WEI=3000000000000000

# BTC chain config (optional, enable when BTC withdraw is needed)
BTC_CHAIN=btc
BTC_FROM_ADDRESS=
BTC_WITHDRAW_FEE_RESERVE_SATS=0
BTC_RPC_HOST=
BTC_RPC_DISABLE_TLS=true
BTC_UTXO_MIN_CONF=1
BTC_FEE_TARGET_BLOCKS=2
BTC_FEE_RATE_SAT_PER_VBYTE=2
BTC_UTXO_RESERVE_TTL_SEC=7200

# signer keys / mnemonic
ETH_HOT_WALLET_PRIV=
BTC_HOT_WALLET_PRIV=
SIGNER_MNEMONIC=

# confirmer thresholds
EVM_CONFIRM_THRESHOLD=5
BTC_CONFIRM_THRESHOLD=2

# optional local test helper
ETH_TO_ADDRESS=
BTC_TO_ADDRESS=

# PostgreSQL config
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASS=redispass
REDIS_DB=0

# Kafka
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC_BROADCAST=tx.broadcast.v1

# service auth
SIGNER_AUTH_SECRET="supersecret-demo"
WITHDRAW_AUTH_SECRET="supersecret-demo"
