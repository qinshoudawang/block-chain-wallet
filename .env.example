# =======================
# Chain Profiles
# =======================

# EVM (required when running EVM withdraw)
ETH_CHAIN=sepolia
ETH_RPC=
ETH_CHAIN_ID=11155111
ETH_FROM_ADDRESS=
ETH_WITHDRAW_GAS_RESERVE_WEI=3000000000000000
ETH_TO_ADDRESS=
EVM_CONFIRM_THRESHOLD=5
EVM_TOKEN_CONTRACTS=

# BTC (required when running BTC withdraw)
# Use canonical chain name for consistency.
BTC_CHAIN=btc-testnet
BTC_FROM_ADDRESS=
BTC_TO_ADDRESS=
BTC_WITHDRAW_FEE_RESERVE_SATS=0
BTC_CONFIRM_THRESHOLD=2
SOL_CONFIRM_THRESHOLD=5

# BTC API (Esplora-compatible)
# Example (testnet): https://blockstream.info/testnet/api
# Host supports full URL or host:port. Full URL is recommended.
BTC_RPC_HOST=
BTC_RPC_DISABLE_TLS=false

# BTC tx builder / reserve tuning
BTC_UTXO_MIN_CONF=1
BTC_FEE_TARGET_BLOCKS=2
BTC_FEE_RATE_SAT_PER_VBYTE=2
BTC_UTXO_RESERVE_TTL_SEC=7200

# RBF (auto trigger)
RBF_STUCK_MINUTES=30

# SOL (required when running SOL withdraw)
SOL_CHAIN=sol
SOL_RPC=
SOL_FROM_ADDRESS=
SOL_TO_ADDRESS=
SOL_WITHDRAW_FEE_RESERVE_LAMPORTS=0
SOL_PRIORITY_FEE_MICRO_LAMPORTS=0

# =======================
# Signer
# =======================
ETH_HOT_WALLET_PRIV=
BTC_HOT_WALLET_PRIV=
SOL_HOT_WALLET_PRIV=
SIGNER_MNEMONIC=
SIGNER_AUTH_SECRET="supersecret-demo"
WITHDRAW_AUTH_SECRET="supersecret-demo"

# =======================
# Infrastructure
# =======================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=
DB_SSLMODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASS=redispass
REDIS_DB=0

# Kafka
KAFKA_BROKERS=127.0.0.1:9092
KAFKA_TOPIC_BROADCAST=tx.broadcast.v1

# gRPC
SIGNER_GRPC_ADDR=127.0.0.1:9001
WITHDRAW_GRPC_ADDR=127.0.0.1:9002

# =======================
# Deposit (EVM)
# =======================
DEPOSIT_EVM_CONFIRMATIONS=6
DEPOSIT_EVM_POLL_SEC=8
DEPOSIT_EVM_BATCH_BLOCKS=10
DEPOSIT_EVM_SUBSCRIBE=0
DEPOSIT_EVM_START_BLOCK=0

# =======================
# Deposit (BTC)
# =======================
DEPOSIT_BTC_CONFIRMATIONS=2
DEPOSIT_BTC_POLL_SEC=60
DEPOSIT_BTC_BATCH_BLOCKS=20
DEPOSIT_BTC_START_BLOCK=0

# =======================
# Deposit (SOL)
# =======================
DEPOSIT_SOL_CONFIRMATIONS=32
DEPOSIT_SOL_POLL_SEC=15
DEPOSIT_SOL_BATCH_BLOCKS=100
DEPOSIT_SOL_START_BLOCK=0

# =======================
# Sweeper (EVM)
# =======================
# Sweeper assets come from EVM_TOKEN_CONTRACTS (one worker per contract).
# Empty means native coin sweep.
# Native sweep min amount (wei); amounts below this are skipped.
SWEEP_EVM_MIN_NATIVE_WEI=1000000000000000
# Token sweep min amount (token atomic unit); adjust per token decimals.
SWEEP_EVM_MIN_TOKEN_ATOMIC=1000000
# Shared gas reserve threshold (wei):
# 1) kept as reserve when sweeping native asset
# 2) minimum ETH balance required before ERC20 sweep (below this triggers top-up)
SWEEP_EVM_GAS_RESERVE_WEI=0
# Native ETH amount sent from hot wallet for each gas top-up.
SWEEP_EVM_TOKEN_TOPUP_WEI=0
SWEEP_EVM_POLL_SEC=30
SWEEP_EVM_LOCK_TTL_SEC=90
SWEEP_EVM_BATCH=200
BROADCAST_CONFIRMER_LOCK_TTL_SEC=20
BROADCAST_CONFIRMER_POLL_SEC=60
SWEEP_AUTH_SECRET="supersecret-demo"

# =======================
# Reconciler (EVM)
# =======================
RECON_EVM_HOT_POLL_SEC=30
RECON_EVM_USER_POLL_SEC=300
RECON_EVM_HOT_LOCK_TTL_SEC=60
RECON_EVM_USER_LOCK_TTL_SEC=180
RECON_EVM_TOLERANCE_WEI=0
RECON_FLOW_POLL_SEC=60
RECON_FLOW_LOCK_TTL_SEC=60
RECON_FLOW_BATCH=500
